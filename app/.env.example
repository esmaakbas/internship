# ===================================================================
# App Configuration File
# ===================================================================
# Copy this file to .env and customize for your environment
# Install python-dotenv for automatic loading: pip install python-dotenv
#
# If you don't create a .env file, the app will use auto-detection
# and default values.
# ===================================================================

# R Configuration
# ---------------
# Path to R executable (leave empty for auto-detection)
# Auto-detection searches common R installation paths
# Example: C:\Program Files\R\R-4.5.3\bin\x64\Rscript.exe
R_EXECUTABLE=

# Path to the R inference script
# Default: auto-detects Capsico_mini_v2 in parent directory
# Example: C:\Users\Windows\Desktop\Capsico_mini_v2\step_inference_mini_both.R
R_SCRIPT_PATH=

# Plumber API Configuration
# ------------------------
# URL of the Plumber API service (without /predict endpoint)
PLUMBER_API_URL=http://localhost:8000

# Alex LLM Guidance API Configuration
# ------------------------------------
ALEX_GUIDANCE_URL=http://localhost:8001/guidance/generate
ALEX_TIMEOUT_SECONDS=30

# Flask -> Alex delegated JWT trust contract (required)
# -----------------------------------------------------
# Must match Alex service verifier settings exactly.
ALEX_DELEGATION_ISSUER=capsico-flask-backend
ALEX_DELEGATION_AUDIENCE=alex-llm-service
ALEX_DELEGATION_KEY_ID=capsico-key-2026-01
ALEX_DELEGATION_TTL_SECONDS=120

# Private key used by Flask to sign delegation JWTs.
# Keep escaped newlines in .env format.
# Example:
# ALEX_DELEGATION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ALEX_DELEGATION_PRIVATE_KEY=

# Flask Application Configuration
# -------------------------------
# Secret key for Flask sessions (CHANGE THIS IN PRODUCTION!)
FLASK_SECRET_KEY=capsico_inference_secret_key_2026

# Enable/disable debug mode (True/False)
FLASK_DEBUG=True

# Port for Flask application
FLASK_PORT=8080

# Host address (127.0.0.1 for local only, 0.0.0.0 for network access)
FLASK_HOST=127.0.0.1

# Database Configuration (MySQL) - REQUIRED
# ------------------------------------------
# These settings are required for the application to connect to MySQL
# The app will fail to start if DB_NAME, DB_USER, or DB_PASS are not set
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mobilab_app
DB_USER=mobilab_user
DB_PASS=mobilab_pass

# Database Connection Pool Settings (Optional - Advanced)
# --------------------------------------------------------
# DB_POOL_SIZE=5          # Base number of connections in pool
# DB_MAX_OVERFLOW=10       # Max connections beyond pool_size
# DB_POOL_TIMEOUT=30       # Seconds to wait for connection from pool
# DB_POOL_RECYCLE=3600     # Recycle connections after N seconds
# DB_CONNECT_TIMEOUT=10    # MySQL connection timeout in seconds
# SQLALCHEMY_ECHO=False    # Log all SQL queries (True/False)

# Auth0 Configuration - OPTIONAL
# --------------------------------
# Authentication is OPTIONAL. The app will run without Auth0 configured.
# If Auth0 is not configured, authentication features will be disabled.
#
# To enable authentication:
# 1. Create a Regular Web Application in Auth0: https://manage.auth0.com/
# 2. Copy Domain, Client ID, and Client Secret
# 3. Add callback URL to "Allowed Callback URLs" in Auth0 settings
# 4. Replace the placeholder values below with real values
#
# Leave these as placeholders to run the app without authentication.
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your_client_id_here
AUTH0_CLIENT_SECRET=your_client_secret_here
AUTH0_CALLBACK_URL=http://127.0.0.1:8080/auth/callback

# Auth0 Audience (Optional - for API authorization)
# AUTH0_AUDIENCE=https://your-tenant.auth0.com/userinfo

# Auth0 Role Claim (set in your Auth0 Action that injects role into ID token)
AUTH0_ROLE_CLAIM=https://mobilab.app/role

# Auth0 Management API - REQUIRED for Admin Panel
# -------------------------------------------------
# The admin panel (user management) requires a SEPARATE Machine-to-Machine
# application in Auth0 with permissions to manage users and roles.
#
# To set this up:
# 1. Go to Auth0 Dashboard → Applications → Create Application
# 2. Select "Machine to Machine Applications"
# 3. Name it "Capsico Management API" (or similar)
# 4. Authorize for "Auth0 Management API" with these scopes:
#    - read:users, create:users, update:users, delete:users
#    - read:roles, create:role_members, delete:role_members
# 5. Copy the Client ID and Client Secret below
#
# Also create roles in Auth0 → User Management → Roles:
# - "admin" role
# - "user" role
AUTH0_MANAGEMENT_CLIENT_ID=your_m2m_client_id_here
AUTH0_MANAGEMENT_CLIENT_SECRET=your_m2m_client_secret_here

# Database connection name for creating users (find in Auth0 → Authentication → Database)
AUTH0_DB_CONNECTION=Username-Password-Authentication

# Debug Routes Security (Optional)
# ---------------------------------
# Comma-separated list of IPs allowed to access /debug/* routes
# ALLOWED_DEBUG_IPS=127.0.0.1,::1

