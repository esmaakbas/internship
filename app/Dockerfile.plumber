FROM rocker/r-ver:4.3.1

# Install plumber and common deps at build time so container is ready
RUN R -e "install.packages(c('plumber','jsonlite','remotes'), repos='https://cran.rstudio.com/')"

WORKDIR /pipeline

# The pipeline folder is mounted at /pipeline (host must provide it)
# Default command runs the R entrypoint script present in the mounted folder
CMD ["Rscript", "run_api.R"]
